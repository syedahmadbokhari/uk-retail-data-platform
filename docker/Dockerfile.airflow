FROM apache/airflow:2.8.1

USER airflow

# Install dbt-postgres and project runtime dependencies into the Airflow image
RUN pip install --no-cache-dir \
    "dbt-postgres>=1.7,<2.0" \
    "psycopg2-binary>=2.9" \
    "scikit-learn>=1.3" \
    "pandas>=2.0" \
    "SQLAlchemy>=2.0" \
    "numpy>=1.24" \
    "plotly>=5.0" \
    "streamlit>=1.30"
